---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="博客 — i2kai">
  <div class="page-intro">
    <h1>博客</h1>
    <p>技术文章、项目动态和开发随想。</p>
  </div>

  {posts.length > 0 ? (
    <div class="blog-list">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="blog-list-item">
          <div>
            <span class="blog-item-title">{post.data.title}</span>
            {post.data.description && (
              <p style="font-size:0.85rem;margin:0.25rem 0 0;color:var(--muted);">{post.data.description}</p>
            )}
          </div>
          <span class="blog-item-date mono">{post.data.date.toLocaleDateString('zh-CN')}</span>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p>博客文章即将到来，敬请期待。</p>
    </div>
  )}
</BaseLayout>
