---
import BaseLayout from '../layouts/BaseLayout.astro';
import { personalInfo, education, experiences, skills, timeline, philosophy } from '../data/site';
---

<BaseLayout title={`关于 — ${personalInfo.name}`}>
  <div class="page-intro">
    <h1>关于我</h1>
    <p>{personalInfo.bio}</p>
  </div>

  <!-- 数据亮点 -->
  <section class="section">
    <div class="stats-row">
      {personalInfo.highlights.map((h) => (
        <div class="stat-card">
          <span class="stat-value">{h.value}</span>
          <span class="stat-label">{h.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- 教育背景 -->
  <section class="section">
    <div class="section-head">
      <h2>教育背景</h2>
    </div>
    <div class="edu-card">
      <div class="edu-info">
        <strong>{education.school}</strong>
        <span class="edu-detail">{education.major} · {education.degree}</span>
        <span class="mono">{education.period}</span>
      </div>
    </div>
  </section>

  <!-- 成长时间线 -->
  <section class="section">
    <div class="section-head">
      <h2>成长时间线</h2>
    </div>
    <div class="timeline">
      {timeline.map((item) => (
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <span class="timeline-year mono">{item.year}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 工作经历 -->
  <section class="section">
    <div class="section-head">
      <h2>工作经历</h2>
    </div>
    <div class="exp-list">
      {experiences.map((exp) => (
        <div class="exp-card">
          <div class="exp-header">
            <h3>{exp.role}</h3>
            <span class="mono exp-period">{exp.period}</span>
          </div>
          <p>{exp.description}</p>
          <div class="exp-tags">
            {exp.highlights.map((h) => (
              <span class="tag-sm">{h}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 技术栈 -->
  <section class="section">
    <div class="section-head">
      <h2>技术栈</h2>
    </div>
    <div class="skills-grid">
      <div class="skill-group">
        <span class="section-label">核心技术</span>
        <div class="skill-bars">
          {skills.core.map((s) => (
            <div class="skill-bar-row">
              <span class="skill-name">{s.name}</span>
              <div class="skill-bar"><div class="skill-fill" style={`width: ${s.level}%`}></div></div>
              <span class="skill-pct mono">{s.level}%</span>
            </div>
          ))}
        </div>
      </div>
      <div class="skill-group">
        <span class="section-label">专业领域</span>
        <div class="skill-bars">
          {skills.domains.map((s) => (
            <div class="skill-bar-row">
              <span class="skill-name">{s.name}</span>
              <div class="skill-bar"><div class="skill-fill" style={`width: ${s.level}%`}></div></div>
              <span class="skill-pct mono">{s.level}%</span>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="skill-extras">
      {skills.extras.map((tag) => (
        <span class="tag-sm">{tag}</span>
      ))}
    </div>
  </section>

  <!-- 开发理念 -->
  <section class="section">
    <div class="section-head">
      <h2>开发理念</h2>
    </div>
    <div class="philosophy-grid">
      {philosophy.map((item, i) => (
        <div class="philosophy-card">
          <span class="philosophy-step">{i + 1}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
