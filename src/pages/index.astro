---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { personalInfo, featuredProjects, projectShowcaseCases } from '../data/site';

const recentPosts = await getCollection('blog', ({ data }) => !data.draft);
recentPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestPost = recentPosts[0];
const typePriority = {
  '年度进度': 0,
  '个人产品': 1,
  '交付案例': 2,
  '企业案例': 3,
  '公开站点': 4,
  '开源项目': 5,
};

const showcasePreview = [...projectShowcaseCases]
  .sort((a, b) => {
    const aPriority = typePriority[a.type] ?? 9;
    const bPriority = typePriority[b.type] ?? 9;

    if (aPriority !== bPriority) return aPriority - bPriority;
    return a.title.localeCompare(b.title, 'zh-CN');
  })
  .filter((item) => item.featured)
  .slice(0, 4);
---

<BaseLayout title={`爱二开网 — ${personalInfo.name}，${personalInfo.title}`}>
  <!-- Hero: 头像 + 签名 -->
  <section class="hero-personal">
    <img class="hero-avatar" src="/avatar.jpg" alt={personalInfo.name} width="96" height="96" />
    <h1 class="hero-name">{personalInfo.name}</h1>
    <p class="hero-title-sub">{personalInfo.title}</p>
    <p class="hero-one-liner">
      {personalInfo.bio}<br/>
      <em class="hero-motto">「先体验，再学习，再读源码。」</em>
    </p>
    <div class="hero-stats">
      {personalInfo.highlights.map((h) => (
        <div class="stat-item">
          <span class="stat-value">{h.value}</span>
          <span class="stat-label">{h.label}</span>
        </div>
      ))}
    </div>
    <div class="hero-links">
      <a href="https://github.com/LuoYaoSheng" target="_blank" rel="noopener">GitHub</a>
      <a href="https://gitee.com/luoyaosheng" target="_blank" rel="noopener">Gitee</a>
      <a href="/about">关于我</a>
      <a href="/contact">联系</a>
    </div>
  </section>

  <!-- 我做什么 -->
  <section class="home-section">
    <h2 class="section-label">我做什么</h2>
    <div class="what-grid">
      <div class="what-item">
        <span class="what-emoji">📡</span>
        <div>
          <strong>BLE & IoT</strong>
          <p>跨平台 BLE 调试工具、ESP32 固件、MQTT 平台</p>
        </div>
      </div>
      <div class="what-item">
        <span class="what-emoji">🖥️</span>
        <div>
          <strong>桌面工具</strong>
          <p>Redis 管理、数据库客户端、SSH 运维工作台</p>
        </div>
      </div>
      <div class="what-item">
        <span class="what-emoji">📱</span>
        <div>
          <strong>移动 & 小程序</strong>
          <p>Flutter 跨平台、微信小程序 BLE 工具</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 开源项目 -->
  <section class="home-section">
    <h2 class="section-label">开源项目</h2>
    <div class="projects-list">
      {featuredProjects.map((project) => (
        <a href={project.docs || project.repo} target="_blank" rel="noopener" class="project-row">
          <div class="project-row-main">
            <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.25rem;">
              <span class="project-row-name">{project.name}</span>
              <span class="tag-sm tag-opensource">开源</span>
            </div>
            <span class="project-row-summary">{project.summary}</span>
          </div>
          <div class="project-row-tags">
            {project.tags.map((tag) => (
              <span class="tag-sm">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
    <a href="https://open.i2kai.com" class="more-link" target="_blank" rel="noopener">所有项目 → open.i2kai.com</a>
  </section>

  <!-- 项目展示 -->
  <section class="home-section">
    <h2 class="section-label">项目展示</h2>
    <div class="home-showcase-grid">
      {showcasePreview.map((item) => (
        <a href={`/showcase/${item.slug}`} class="home-showcase-card">
          {item.image && (
            <img src={item.image} alt={item.title} loading="lazy" />
          )}
          <span>{item.type} / {item.category}</span>
          <strong>{item.title}</strong>
          <p>{item.summary}</p>
        </a>
      ))}
    </div>
    <a href="/showcase" class="more-link">项目展示专题</a>
  </section>

  <!-- 最近写的内容 -->
  {latestPost && (
    <section class="home-section">
      <h2 class="section-label">最近写的内容</h2>
      <a href={`/blog/${latestPost.slug}`} class="post-teaser">
        <span class="post-teaser-title">{latestPost.data.title}</span>
        <span class="post-teaser-date mono">{latestPost.data.date.toLocaleDateString('zh-CN')}</span>
      </a>
      <a href="/blog" class="more-link">更多文章</a>
    </section>
  )}

  <!-- 公众号 -->
  <section class="home-section">
    <h2 class="section-label">公众号</h2>
    <div class="wechat-grid">
      <div class="wechat-qr-box">
        <img src="/wechat-qr.jpg" alt="极客第一行二维码" width="120" height="120" />
        <div class="wechat-qr-text">
          <strong>{personalInfo.wechatPublic}</strong>
          <p>物联网、微服务、分布式系统实战经验。</p>
        </div>
      </div>
      <div class="wechat-qr-box">
        <img src="/wechat-qr-2.jpg" alt="落落在厦二维码" width="120" height="120" />
        <div class="wechat-qr-text">
          <strong>{personalInfo.wechatPublic2}</strong>
          <p>生活记录与分享。</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
