---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { featuredProjects, projectGroups, docSites } from '../data/site';

const openSourceGroups = projectGroups.filter(g => g.title !== '企业级项目' && g.title !== '其他个人项目');
const enterpriseGroup = projectGroups.find(g => g.title === '企业级项目');
const otherGroup = projectGroups.find(g => g.title === '其他个人项目');
---

<BaseLayout title="项目 — i2kai">
  <div class="page-intro">
    <h1>项目</h1>
    <p>开源项目、企业级项目和个人产品的完整展示。</p>
  </div>

  {openSourceGroups.map((group) => (
    <section class="section">
      <div class="section-head">
        <div>
          <h2>{group.title}</h2>
          <p>{group.intro}</p>
        </div>
      </div>
      <div class="section-grid">
        {group.items.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>
  ))}

  {enterpriseGroup && (
    <section class="section">
      <div class="section-head">
        <div>
          <h2>{enterpriseGroup.title}</h2>
          <p>{enterpriseGroup.intro}</p>
        </div>
      </div>
      <div class="section-grid">
        {enterpriseGroup.items.map((project) => (
          <div class="section-card">
            <div class="meta-row">
              <span class="tag-sm tag-enterprise">企业</span>
              <div class="meta-row" style="margin-bottom:0">
                {project.tags.map((tag) => (
                  <span class="meta-pill">{tag}</span>
                ))}
              </div>
            </div>
            <h3>{project.name}</h3>
            <p>{project.summary}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {otherGroup && (
    <section class="section">
      <div class="section-head">
        <div>
          <h2>{otherGroup.title}</h2>
          <p>{otherGroup.intro}</p>
        </div>
      </div>
      <div class="section-grid">
        {otherGroup.items.map((project) => (
          <div class="section-card">
            <div class="meta-row">
              <span class="tag-sm tag-online">已上线</span>
              <div class="meta-row" style="margin-bottom:0">
                {project.tags.map((tag) => (
                  <span class="meta-pill">{tag}</span>
                ))}
              </div>
            </div>
            <h3>{project.name}</h3>
            <p>{project.summary}</p>
            {project.repo && (
              <a href={project.repo} target="_blank" rel="noopener">访问 →</a>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-head">
      <div>
        <h2>文档站入口</h2>
        <p>每个开源项目都有独立的文档站。</p>
      </div>
    </div>
    <div class="section-grid">
      {docSites.map((site) => (
        <a href={site.url} target="_blank" rel="noopener" class="section-card doc-link-card">
          <h3>{site.name}</h3>
          <span class="mono">{new URL(site.url).hostname}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
