---
import '../styles/global.css';
import { seoMeta } from '../data/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = '12年+全栈技术开发与管理经验，专注于物联网技术架构、智慧城市解决方案和分布式系统开发。',
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, seoMeta.siteUrl);
const ogImage = image || seoMeta.ogImage;

const navItems = [
  { label: '首页', href: '/' },
  { label: '关于', href: '/about' },
  { label: '项目', href: '/showcase' },
  { label: '博客', href: '/blog' },
  { label: '视频', href: '/videos' },
  { label: '联系', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isActiveNav = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={seoMeta.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, seoMeta.siteUrl)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Extra SEO -->
    <meta name="keywords" content={seoMeta.keywords} />
    <meta name="author" content={seoMeta.author} />
    <meta name="theme-color" content={seoMeta.themeColor} />

    <!-- 防闪烁：在渲染前注入 dark class -->
    <script is:inline>
      (function () {
        var key = 'i2kai-theme';
        var stored = localStorage.getItem(key);
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">爱二开网</a>
        <nav class="nav">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[isActiveNav(item.href) && 'active']}
            >
              {item.label}
            </a>
          ))}
          <button class="theme-toggle" id="theme-toggle" aria-label="切换暗色模式" title="切换暗色模式">
            <span class="theme-icon-light">☀️</span>
            <span class="theme-icon-dark">🌙</span>
          </button>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-main">
          <span>&copy; {new Date().getFullYear()} {seoMeta.author}</span>
          <span>
            <a href="https://github.com/LuoYaoSheng" target="_blank" rel="noopener">GitHub</a>
            &nbsp;&middot;&nbsp;
            <a href="https://gitee.com/luoyaosheng" target="_blank" rel="noopener">Gitee</a>
          </span>
        </div>
        <div class="footer-beian">
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">闽ICP备2022003862号</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  .nav a.active {
    color: var(--ink);
    font-weight: 600;
  }
</style>

<!-- 主题切换点击逻辑 -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var key = 'i2kai-theme';
      var isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem(key, isDark ? 'dark' : 'light');
    });
  });
</script>
